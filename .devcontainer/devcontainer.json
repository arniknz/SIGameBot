{
    "name": "SIGameBot",
    "dockerComposeFile": [
        "../docker-compose.yml",
        "docker-compose.yml"
    ],
    "service": "bot",
    "workspaceFolder": "/workspaces/SIGameBot",
    "forwardPorts": [8000],
    "portsAttributes": {
        "8000": {
            "label": "Admin API",
            "onAutoForward": "openPreview",
            "visibility": "public"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-azuretools.vscode-docker"
            ]
        }
    },
    "remoteUser": "vscode",
    "shutdownAction": "stopCompose"
}
