{
    "name": "SIGameBot",
    "dockerComposeFile": [
        "../docker-compose.yml"
    ],
    "service": "bot",
    "workspaceFolder": "/app",
    "forwardPorts": [8000],
    "portsAttributes": {
        "8000": {
            "label": "Admin API",
            "onAutoForward": "openPreview",
            "visibility": "public"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-azuretools.vscode-docker"
            ]
        }
    },
    "postCreateCommand": "docker compose up -d",
    "remoteUser": "vscode",
    "shutdownAction": "stopCompose"
}
